# =============================================================================
# Social Reaction Analysis GR — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# All variables are optional unless marked REQUIRED.
# Variables with a default show the value used when the variable is omitted.
# =============================================================================


# -----------------------------------------------------------------------------
# Database  (all phases)
# -----------------------------------------------------------------------------
# Async SQLAlchemy URL used by the API and worker.
# Alembic converts postgresql+asyncpg:// → postgresql:// automatically.
# Default matches the Docker Compose `db` service.
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/social_reaction

# For local development (db exposed on port 5432 by Docker Compose):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/social_reaction


# -----------------------------------------------------------------------------
# LLM Provider  (Phase 3 — Enrichment)
# -----------------------------------------------------------------------------
# The LLM model string. Auto-detected from available keys when omitted:
#   1. GROQ_API_KEY set  → groq/meta-llama/llama-4-scout-17b-16e-instruct
#   2. GEMINI_API_KEY    → gemini/gemini-2.0-flash
#   3. Fallback          → ollama/gemma3:4b  (local Ollama, no API key needed)

# --- Option A: Groq (free tier, fast) ---
# GROQ_API_KEY=gsk_YOUR_KEY_HERE
# LLM_MODEL=groq/meta-llama/llama-4-scout-17b-16e-instruct

# --- Option B: Google Gemini ---
# GEMINI_API_KEY=YOUR_KEY_HERE
# LLM_MODEL=gemini/gemini-2.0-flash

# --- Option C: OpenAI ---
# OPENAI_API_KEY=sk-YOUR_KEY_HERE
# LLM_MODEL=gpt-4o-mini

# --- Option D: Local Ollama (no API key required) ---
# LLM_MODEL=ollama/gemma3:4b

# Maximum LLM response tokens (default: 512)
# LLM_MAX_TOKENS=512

# Temperature for classification/summarisation calls; 0 = deterministic (default: 0)
# LLM_TEMPERATURE=0


# -----------------------------------------------------------------------------
# Geocoding — Nominatim  (Phase 3)
# -----------------------------------------------------------------------------
# Base URL for Nominatim. Default: self-hosted Docker Compose `nominatim` service.
# NOMINATIM_URL=http://nominatim:8080

# User-agent required by OSM Nominatim fair-use policy (public instance only).
# NOMINATIM_USER_AGENT=social-reaction-analysis-gr/1.0 nektarios.tp@gmail.com

# Seconds between Nominatim requests (OSM fair-use = 1 req/sec; default: 1.1)
# NOMINATIM_DELAY_SECONDS=1.1


# -----------------------------------------------------------------------------
# Embedding Model  (Phase 2 — NLP)
# -----------------------------------------------------------------------------
# sentence-transformers model. Validated default (silhouette ≈ 0.49):
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2


# -----------------------------------------------------------------------------
# Clustering — HDBSCAN  (Phase 2)
# -----------------------------------------------------------------------------
# Minimum articles to form a cluster (default: 3)
# CLUSTER_MIN_ARTICLES=3

# Minimum mean intra-cluster cosine similarity (default: 0.78)
# CLUSTER_MIN_INTRA_SIM=0.78


# -----------------------------------------------------------------------------
# Pipeline Worker  (Phase 1–3)
# -----------------------------------------------------------------------------
# What the worker runs each cycle:
#   scrape_only      — ingestion only (default)
#   scrape_and_nlp   — ingestion + Phase 2 NLP
#   full             — ingestion + NLP + Phase 3 enrichment (requires LLM key)
# PIPELINE_MODE=scrape_only

# How often the worker runs, in seconds (default: 1800 = 30 min)
# PIPELINE_INTERVAL_SECONDS=1800