# =============================================================================
# Social Reaction Analysis GR — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# All variables are optional unless marked REQUIRED.
# Variables with a default show the value that will be used when omitted.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM Provider  (Phase 4 — LLM Processing)
# -----------------------------------------------------------------------------
# The LLM model string passed to litellm.completion().
# When LLM_MODEL is not set, _auto_model() selects automatically:
#   1. If GROQ_API_KEY is set   → groq/llama-3.3-70b-versatile
#   2. If GEMINI_API_KEY is set → gemini/gemini-2.0-flash
#   3. Fallback                 → ollama/gemma3:4b  (local, no API key needed)
#
# Uncomment ONE of the blocks below (and the matching API key).

# --- Option A: Groq (free tier, fast inference, 500K TPD) ---
# GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE
# LLM_MODEL=groq/meta-llama/llama-4-scout-17b-16e-instruct

# --- Option B: Google Gemini (free tier available) ---
# GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# LLM_MODEL=gemini/gemini-2.0-flash

# --- Option C: OpenAI ---
# OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE
# LLM_MODEL=gpt-4o-mini

# --- Option D: Local Ollama (no API key, requires Ollama running locally) ---
# LLM_MODEL=ollama/gemma3:4b

# Maximum tokens for LLM responses (default: 512)
# LLM_MAX_TOKENS=512

# Temperature for classification / summarisation calls (default: 0 = deterministic)
# LLM_TEMPERATURE=0


# -----------------------------------------------------------------------------
# Geocoding — Nominatim  (Phase 4)
# -----------------------------------------------------------------------------
# User-agent string required by OSM Nominatim fair-use policy.
# Change to your project name / contact email.
# NOMINATIM_USER_AGENT=social-reaction-analysis-gr/1.0

# Seconds between Nominatim requests (OSM fair-use = 1 req/sec; default: 1.1)
# NOMINATIM_DELAY_SECONDS=1.1


# -----------------------------------------------------------------------------
# Data Paths  (Phase 2 & 3)
# -----------------------------------------------------------------------------
# Directory where scrapers write raw .ndjson files (default: data/raw)
# OUTPUT_DIR=data/raw

# Directory where ChromaDB persists its vector store (default: data/vectordb)
# VECTORDB_DIR=data/vectordb


# -----------------------------------------------------------------------------
# Embedding Model  (Phase 3 — NLP)
# -----------------------------------------------------------------------------
# Sentence-transformer model name from HuggingFace.
# Best validated option (silhouette 0.4911):
#   sentence-transformers/paraphrase-multilingual-mpnet-base-v2
# Alternative (lower silhouette but richer embeddings):
#   intfloat/multilingual-e5-large  (requires EMBEDDING_PROMPT_PREFIX=passage: )
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# Maximum token length for the embedding model (default: 128)
# EMBEDDING_MAX_SEQ_LENGTH=128

# Prefix prepended to every text before encoding.
# Required for E5 models ("passage: "). Leave empty for paraphrase-* / MiniLM-*.
# EMBEDDING_PROMPT_PREFIX=

# Batch size for encoding (tune based on GPU/CPU memory; default: 64)
# EMBEDDING_BATCH_SIZE=64

# ChromaDB collection name (default: articles)
# CHROMA_COLLECTION_NAME=articles


# -----------------------------------------------------------------------------
# Clustering — HDBSCAN  (Phase 3)
# -----------------------------------------------------------------------------
# Minimum number of articles to form a cluster (default: 2)
# HDBSCAN_MIN_CLUSTER_SIZE=2

# Density threshold; lower = more clusters (default: 1)
# HDBSCAN_MIN_SAMPLES=1


# -----------------------------------------------------------------------------
# Post-Clustering Quality Filters  (Phase 3)
# -----------------------------------------------------------------------------
# Minimum articles per cluster; clusters below this are demoted to noise.
# Validated optimum from cluster_analytics.ipynb: 3
# CLUSTER_MIN_ARTICLES=3

# Minimum mean pairwise intra-cluster cosine similarity (0.0 = disabled).
# Validated optimum: 0.78
# CLUSTER_MIN_INTRA_SIM=0.0

# Minimum cosine similarity to any reaction-category description.
# Clusters below this threshold are off-topic and demoted to noise (default: 0.25)
# CLUSTER_MIN_RELEVANCE_SIM=0.25


# -----------------------------------------------------------------------------
# Deduplication  (Phase 3)
# -----------------------------------------------------------------------------
# Cosine similarity above which two records are considered duplicates (default: 0.85)
# DEDUP_SIMILARITY_THRESHOLD=0.85

# Maximum hours between two records to be considered duplicates (default: 96)
# DEDUP_MAX_TIME_DIFF_HOURS=96


# -----------------------------------------------------------------------------
# Stable Event ID Registry  (Phase 3)
# -----------------------------------------------------------------------------
# Cosine similarity threshold for matching a new cluster to an existing event.
# Higher = stricter matching → more new event IDs created per run (default: 0.85)
# EVENT_ID_MATCH_THRESHOLD=0.85


# -----------------------------------------------------------------------------
# Scraper Scheduler  (Phase 2)
# -----------------------------------------------------------------------------
# How often the scheduler runs the pipeline, in seconds (default: 3600 = 1 hour)
# SCRAPE_INTERVAL_SECONDS=3600

# What to execute each scheduled cycle:
#   scrape_only     — scrapers only (default)
#   scrape_and_nlp  — scrape → Phase 3 NLP pipeline
#   full            — scrape → NLP → Phase 4 LLM pipeline (requires LLM API key)
# PIPELINE_MODE=scrape_only

# Politeness delay between HTTP requests in scrapers, seconds (default: 2)
# REQUEST_DELAY_SECONDS=2


# -----------------------------------------------------------------------------
# GDELT  (Phase 2)
# -----------------------------------------------------------------------------
# Number of 15-minute GDELT 2.0 update files to process per run.
# 4 = last 60 minutes (default: 4)
# GDELT_LOOKBACK_FILES=4

# Time window for the GDELT DOC API query, in minutes.
# 1440 = last 24 hours (default: 1440)
# GDELT_TIMESPAN_MINUTES=1440


# -----------------------------------------------------------------------------
# ACLED  (Phase 2 — disabled by default; Research tier only covers data > 12 months old)
# -----------------------------------------------------------------------------
# myACLED account credentials for OAuth2 token authentication.
# ACLED_EMAIL=your-email@example.com
# ACLED_PASSWORD=your-acled-password

# Set to true for a one-time historical bulk load (2018 → today−12 months).
# ACLED_HISTORICAL_MODE=false

# Start date for the one-time historical bulk load (default: 2018-01-01)
# ACLED_HISTORICAL_SINCE=2018-01-01

# Days before the 12-month cutoff to fetch per scheduled run (default: 7)
# ACLED_LOOKBACK_DAYS=7
